generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum District {
  Centrum
  StareMiasto
  NoweMiasto
  Jezyce
  Grunwald
  Wilda
  Inny
}

enum Category {
  Kino
  Sztuka
  Muzyka
  Sport
  Teatr
  Warsztaty
  Konferencje
  Jedzenie
  Inne
}

enum Vibe {
  Randka
  Impreza
  WyjscieZeZnajomymi
  Rodzinne
  Spokojne
  Kulturalne
  Aktywne
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AttendStatus {
  GOING
  SAVED
  INTERESTED
}

enum ActivityType {
  GOING
  SAVED
  REVIEWED
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  coverImage    String?
  district      District?
  handle        String?  @unique
  bio           String?
  pushSubscription String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  sentFriendships     Friendship[] @relation("SentFriendships")
  receivedFriendships Friendship[] @relation("ReceivedFriendships")
  attendance      Attendance[]
  activities      Activity[]
  notifications   Notification[]
  savedEvents     SavedEvent[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())

  sender   User @relation("SentFriendships", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model Attendance {
  id        String       @id @default(cuid())
  userId    String
  eventId   String
  status    AttendStatus @default(GOING)
  createdAt DateTime     @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  eventId   String
  type      ActivityType @default(GOING)
  createdAt DateTime     @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  type      String
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, read])
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  sourceUrl   String
  startDate   DateTime
  endDate     DateTime
  time        String?
  placeName   String
  address     String?
  district    District @default(Inny)
  category    Category @default(Inne)
  source      String   @default("manual")
  sourceId    String?
  score       Float    @default(0)
  price       String?
  outdoor     Boolean  @default(false)
  coordsX     Float?
  coordsY     Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vibes       EventVibe[]
  attendance  Attendance[]
  activities  Activity[]
  savedEvents SavedEvent[]
  notifications Notification[]

  @@unique([title, startDate, placeName])
  @@index([district])
  @@index([category])
  @@index([score])
  @@index([startDate])
  @@index([endDate])
  @@index([endDate, score])
  @@index([endDate, district, score])
  @@index([startDate, score])
}

model EventVibe {
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vibe    Vibe

  @@id([eventId, vibe])
  @@index([vibe])
}
